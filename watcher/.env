# Root UNC path to scan
WATCH_ROOT=\\file\0-V2\04-DEPARTMENT\02-PO COMMITEE\13-PRESENTATION\02-P-PHOTOS

# Your backend server URL (change IP if backend is on a different machine)
API_BASE_URL=http://localhost:5001

# Must be the SAME value as WATCHER_API_KEY in Ai-fashion/Backend/.env
WATCHER_API_KEY=watcher-fashion-2026

# How many images to upload in parallel (5–10 recommended)
CONCURRENCY=10

# Tracks already-processed images so they are never sent twice
PROCESSED_LOG=./processed.json

# Leave as [] — backend uses the category from the folder name to decide schema
EXTRACTION_SCHEMA=[]

# ── FLAT MODE ──────────────────────────────────────────────────────────────────
# Set to true when WATCH_ROOT points directly at a folder of images (no
# YEAR/MONTH/DIVISION/DATE hierarchy).  All images under WATCH_ROOT are
# processed using the DEFAULT_* values below as metadata.
FLAT_MODE=false

# Optional: metadata applied to every image in flat mode.
# Leave blank to let the AI extract / infer these from the image.
DEFAULT_DIVISION=
DEFAULT_SUB_DIVISION=
DEFAULT_VENDOR_NAME=
DEFAULT_VENDOR_CODE=
DEFAULT_MAJOR_CATEGORY=
DEFAULT_MC_CODE=
