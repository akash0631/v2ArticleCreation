# Root UNC path to scan (update if needed)
WATCH_ROOT=\\File\0-v2\04-DEPARTMENT\02-PO COMMITEE\13-PRESENTATION\02-P-PHOTOS

# Your backend server URL
API_BASE_URL=http://localhost:5000

# Must match WATCHER_API_KEY in your backend .env
WATCHER_API_KEY=your-secret-watcher-key-here

# How many images to upload in parallel (5–10 recommended; raise carefully)
CONCURRENCY=5

# Path to the file that tracks already-processed images (relative or absolute)
PROCESSED_LOG=./processed.json

# Extraction schema JSON — copy from your frontend's schema config
# Leave as [] to send empty schema (backend will use category default)
EXTRACTION_SCHEMA=[]

# ── FLAT MODE ──────────────────────────────────────────────────────────────────
# Set to true when WATCH_ROOT points directly at a folder of images (no
# YEAR/MONTH/DIVISION/DATE hierarchy).  All images under WATCH_ROOT are
# processed and the DEFAULT_* fields are used as metadata.
FLAT_MODE=false

# Optional metadata applied to every image in flat mode.
# Leave blank to let the AI extract / infer these from the image.
DEFAULT_DIVISION=
DEFAULT_SUB_DIVISION=
DEFAULT_VENDOR_NAME=
DEFAULT_VENDOR_CODE=
DEFAULT_MAJOR_CATEGORY=
DEFAULT_MC_CODE=
