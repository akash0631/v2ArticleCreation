# ============================================================================
# AI Fashion Extractor - Frontend Environment Configuration
# ============================================================================
# SETUP: Copy this file to .env and fill in your values
#   cp .env.example .env
#
# For LOCAL development — no changes needed, defaults work out of the box.
# ============================================================================

# Backend API base URL (leave empty for local dev — auto-detects localhost:5001)
# VITE_API_BASE_URL=http://localhost:5001/api

# App display name (optional)
VITE_APP_NAME=AI Fashion Attribute Extractor

# Max file upload size in bytes (default 10MB)
VITE_MAX_FILE_SIZE=10485760
